<section class="archive">
  <header class="section-heading"><h1><%= page.title || __('archives') %></h1><span><%= page.posts.length %> <%= __('articles') %></span></header>
  <% let year; page.posts.each(post => { const y = date(post.date, 'YYYY'); if (y !== year) { year = y; %><h2 class="archive-year"><%= year %></h2><% } %>
    <div class="archive-item"><time><%= date(post.date, 'MM-DD') %></time><a href="<%= url_for(post.path) %>"><%= post.title %></a><span><%= author_info(post.author).name %></span></div>
  <% }) %>
</section>

